@model FileX.Models.Snapshot
@using FileX.Enums

@{
    ViewData["Title"] = "Scan Results";
    var filesByState = Model.Files.GroupBy(f => f.State).ToDictionary(g => g.Key, g => g.ToList());
    var dirsByState = Model.Directories.GroupBy(d => d.State).ToDictionary(g => g.Key, g => g.ToList());
    var totalSizeMb = Model.Files.Sum(f => f.Size) / (1024.0 * 1024.0);
}

<div class="container">
    <div class="mb-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Scan another folder</a>
        <a asp-controller="Home" asp-action="ViewSnapshot" asp-route-rootPath="@Model.RootPath" class="btn btn-primary">Scan this folder again</a>
    </div>
    <h2>Scan Results</h2>
    <p><strong>Root Path:</strong> @Model.RootPath</p>
    <p><strong>Created At:</strong> @Model.CreatedAtUtc.ToLocalTime()</p>
    @if (Model.PreviousSnapshotCreatedAtUtc.HasValue)
    {
        <p><strong>Previous Scan Created At:</strong> @Model.PreviousSnapshotCreatedAtUtc.Value.ToLocalTime()</p>
    }
    <p><strong>Total Size:</strong> @totalSizeMb.ToString("F2") MB</p>

    <ul class="nav nav-tabs" id="snapshotTabs" role="tablist">
        @foreach (var state in Enum.GetValues<FileState>())
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link @(state == FileState.New ? "active" : "")" id="@($"{state}-tab")" data-bs-toggle="tab" data-bs-target="#@($"{state}-pane")" type="button" role="tab" aria-controls="@($"{state}-pane")" aria-selected="@(state == FileState.New)">@state</button>
            </li>
        }
    </ul>

    <div class="tab-content" id="snapshotTabsContent">
        @foreach (var state in Enum.GetValues<FileState>())
        {
            <div class="tab-pane fade @(state == FileState.New ? "show active" : "")" id="@($"{state}-pane")" role="tabpanel" aria-labelledby="@($"{state}-tab")">
                @if (filesByState.ContainsKey(state))
                {
                    <h4 class="mt-3">Files</h4>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Relative Path</th>
                                <th>Version</th>
                                <th>Size (bytes)</th>
                                <th>Last Modified</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var file in filesByState[state])
                            {
                                <tr>
                                    <td>@file.RelativePath</td>
                                    <td>@($"v{file.Version}")</td>
                                    <td>@file.Size</td>
                                    <td>@file.LastModifiedUtc.ToLocalTime()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (dirsByState.ContainsKey(state))
                {
                    <h4 class="mt-3">Directories</h4>
                    <ul class="list-group">
                        @foreach (var dir in dirsByState[state])
                        {
                            <li class="list-group-item">@dir.RelativePath</li>
                        }
                    </ul>
                }
            </div>
        }
    </div>

</div>
